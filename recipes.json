{
    "番茄炒蛋": {
        "meta": "家常菜 | 約15分鐘 | 2人份",
        "ingredients": [
            "番茄 2顆",
            "雞蛋 3顆",
            "蒜頭 2瓣",
            "鹽 適量",
            "糖 少許",
            "醬油 1茶匙",
            "香油 少許",
            "蔥花 適量"
        ],
        "steps": [
            "番茄洗淨切塊，蒜頭切末，備用。",
            "雞蛋打入碗中加少許鹽攪散，下鍋炒至半熟盛起。",
            "原鍋加油爆香蒜末，放入番茄中大火翻炒，炒至出汁。",
            "倒回雞蛋，加鹽、糖、醬油調味，拌炒均勻。",
            "起鍋前淋少許香油，撒上蔥花即可上桌。"
        ]
    },
    "滷肉飯": {
        "meta": "台灣小吃 | 約60分鐘 | 4人份",
        "ingredients": [
            "豬五花肉 400g",
            "紅蔥頭 6顆",
            "醬油 4湯匙",
            "米酒 2湯匙",
            "冰糖 1湯匙",
            "八角 2顆",
            "水 300ml",
            "白飯 適量",
            "滷蛋 適量(可選)"
        ],
        "steps": [
            "五花肉切細丁或粗末，紅蔥頭去皮切薄片。",
            "乾鍋炒香紅蔥頭至金黃酥脆，盛起備用。",
            "原鍋下肉末，翻炒至出油變色。",
            "加入醬油、米酒、冰糖、八角拌炒上色。",
            "倒入水及炸蔥頭，蓋鍋以小火燉煮40分鐘，期間偶爾攪拌。",
            "開蓋收汁至濃稠，淋在白飯上即可享用。"
        ]
    },
    "宮保雞丁": {
        "meta": "川菜 | 約25分鐘 | 2人份",
        "ingredients": [
            "雞胸肉 300g",
            "乾辣椒 8條",
            "花生 50g",
            "蔥段 適量",
            "薑片 3片",
            "蒜末 2茶匙",
            "太白粉 1茶匙",
            "醬油 2湯匙",
            "陳醋 1湯匙",
            "糖 1湯匙",
            "花椒粉 少許",
            "麻油 少許"
        ],
        "steps": [
            "雞胸肉切丁，加醬油、太白粉抓醃10分鐘。",
            "調好醬汁：醬油、陳醋、糖、少許太白粉水混合備用。",
            "熱鍋加油，放花椒粉、乾辣椒炒香，注意火候避免焦苦。",
            "下雞丁大火翻炒至變色，加蒜末、薑片、蔥段炒香。",
            "倒入醬汁，快速拌炒至收汁裹勻。",
            "加入花生，淋麻油，出鍋裝盤。"
        ]
    },
    "麻婆豆腐": {
        "meta": "川菜 | 約20分鐘 | 2人份",
        "ingredients": [
            "嫩豆腐 1盒",
            "豬絞肉 100g",
            "豆瓣醬 1.5湯匙",
            "醬油 1湯匙",
            "蒜末 2茶匙",
            "薑末 1茶匙",
            "蔥花 適量",
            "花椒粉 少許",
            "太白粉水 適量",
            "高湯 100ml"
        ],
        "steps": [
            "嫩豆腐切2cm塊狀，放入淡鹽水中浸泡備用。",
            "熱鍋炒香絞肉至變色，盛起備用。",
            "原鍋炒蒜末、薑末及豆瓣醬至出紅油飄香。",
            "倒入高湯，放回絞肉，放入豆腐輕輕推動，中火煮3分鐘。",
            "加醬油調味，勾太白粉水至湯汁濃稠。",
            "起鍋撒花椒粉和蔥花，即可享用。"
        ]
    },
    "蒜泥白肉": {
        "meta": "川菜 | 約30分鐘 | 3人份",
        "ingredients": [
            "豬五花肉 400g",
            "大蒜 6瓣",
            "醬油 2湯匙",
            "陳醋 1湯匙",
            "辣油 1湯匙",
            "糖 少許",
            "香油 少許",
            "薑片 3片",
            "蔥段 2根",
            "小黃瓜 1根(墊底)"
        ],
        "steps": [
            "五花肉冷水下鍋，加薑片、蔥段，煮沸後轉小火20分鐘。",
            "撈出肉塊泡冷水降溫，讓口感更Q彈。",
            "大蒜搗成泥，加醬油、陳醋、糖調成蒜泥醬汁。",
            "小黃瓜切薄片鋪盤底。",
            "五花肉切薄片整齊排在小黃瓜上。",
            "淋上蒜泥醬汁，最後淋辣油與香油即可。"
        ]
    },
    "炒青菜": {
        "meta": "家常菜 | 約10分鐘 | 2人份",
        "ingredients": [
            "空心菜或小白菜 300g",
            "大蒜 3瓣",
            "鹽 適量",
            "油 1湯匙",
            "醬油膏 少許(可選) "
        ],
        "steps": [
            "青菜洗淨，較粗的梗切斷，大蒜拍碎。",
            "鍋子燒熱至冒煙，倒油爆香蒜末。",
            "大火下菜梗先炒30秒，再放菜葉快速翻炒。",
            "加鹽調味，炒至菜葉軟化但仍翠綠即可起鍋。"
        ]
    },
    "雞蛋羹": {
        "meta": "家常菜 | 約20分鐘 | 2人份",
        "ingredients": [
            "雞蛋 3顆",
            "溫水 280ml",
            "鹽 1/4茶匙",
            "醬油 少許",
            "香油 少許",
            "蔥花 適量"
        ],
        "steps": [
            "雞蛋打散，加鹽攪勻，緩緩倒入溫水 (水:蛋 = 1.5:1)，輕攪至均勻。",
            "用細篩過濾蛋液，去除泡沫，使蒸出的羹更細滑。",
            "碗蓋上保鮮膜或蓋子，中小火蒸12~15分鐘至凝固。",
            "取出後淋醬油、香油，撒蔥花即完成。"
        ]
    },
    "紅燒排骨": {
        "meta": "家常菜 | 約50分鐘 | 3人份",
        "ingredients": [
            "豬排骨 600g",
            "薑片 4片",
            "蔥段 2根",
            "醬油 3湯匙",
            "老抽 1湯匙",
            "米酒 2湯匙",
            "冰糖 1湯匙",
            "八角 2顆",
            "水 適量"
        ],
        "steps": [
            "排骨切段，冷水下鍋加薑片汆燙，撈起洗淨血水。",
            "鍋中加少許油，放冰糖小火炒至焦糖色。",
            "放入排骨翻炒上糖色。",
            "加醬油、老抽、米酒、八角、蔥段，倒入剛好蓋過食材的水。",
            "大火煮沸後轉小火燉35分鐘至肉軟入味。",
            "開蓋大火收汁至濃稠，裝盤即可。"
        ]
    },
    "泡麵": {
        "meta": "家常菜 | 約5分鐘 | 1人份",
        "ingredients": [
            "20包泡麵"
        ],
        "steps": [
            "泡20包泡麵"
        ]
    },
